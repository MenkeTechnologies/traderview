/target
**/target
**/*.rs.bk
Cargo.lock.bak

# sqlx offline cache (regenerate with `cargo sqlx prepare`)
.sqlx/

# Tauri build artifacts
/src-tauri/gen/schemas
/src-tauri/WixTools

# Frontend vendored libs (re-fetch with scripts/vendor-uplot.sh)
/frontend/lib/uPlot.iife.min.js
/frontend/lib/uPlot.min.css

# Postgres data (embedded mode writes here in dev)
.tv-data/

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Env / secrets
.env
.env.local
*.pem

# Un-ignore the docs/ site (global gitignore excludes docs/ by default)
!docs/
!docs/**

# Generated at every cargo build by src-tauri/build.rs — content tracks
# workspace.package.version, so it'd churn the git diff for no reason.
frontend/.version.json
