{
  "name": "traderview",
  "version": "0.1.1",
  "private": true,
  "description": "Traderview — Rust backend + vanilla JS frontend",
  "scripts": {
    "test":           "pnpm --filter traderview-frontend test && cargo test --workspace --lib",
    "test:frontend":  "pnpm --filter traderview-frontend test",
    "test:rust":      "cargo test --workspace --lib",
    "test:vitest":    "pnpm --filter traderview-frontend test:vitest",
    "test:node":      "pnpm --filter traderview-frontend test:node",
    "test:watch":     "pnpm --filter traderview-frontend test:watch",
    "i18n:server":    "docker run -d --name libretranslate -p 5050:5000 -e LT_THREADS=8 -e LT_BATCH_LIMIT=400 -e LT_REQ_TIME_LIMIT=600 libretranslate/libretranslate",
    "i18n:server:stop": "docker rm -f libretranslate",
    "i18n:translate": "node frontend/scripts/i18n_translate.mjs"
  }
}
