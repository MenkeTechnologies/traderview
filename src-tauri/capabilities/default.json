{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for traderview-desktop",
  "windows": ["main", "tile-*"],
    "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "allow-get-api-config",
    "allow-get-log-path",
    "allow-read-log-tail",
    "allow-get-process-stats",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "window-state:default"
  ]
}
